@page
@model AMCOS.Web.Core.Pages.App.Lite.IndexModel
@{
    ViewData["Title"] = "AMCOS Lite";
    // Pay plans grouped by their option group (military / civilian) for the dropdown.
    // GroupTitle comes from lookup.payplan as "Military"/"Civilian" — normalise case.
    var payPlanGroups = Model.PayPlans
        .GroupBy(p => string.IsNullOrWhiteSpace(p.OptionGroup) ? "other" : p.OptionGroup.ToLowerInvariant())
        .OrderBy(g => g.Key == "military" ? 0 : g.Key == "civilian" ? 1 : 2);
    string GroupLabel(string key) => key switch
    {
        "military" => "Military",
        "civilian" => "Civilian",
        _ => "Other"
    };
}

<div class="reportPage">
    <h1 class="h3">AMCOS Lite</h1>
    <p class="text-muted">
        This tool allows you to view costs for specified personnel. Choose a pay plan, then narrow by
        category and location; the available filters change based on the pay plan you select.
    </p>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Filters</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.LoadError))
                {
                    <div class="alert alert-warning">@Model.LoadError</div>
                }
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="payPlanList">Pay Plan</label>
                        <select id="payPlanList" class="form-select">
                            <option value="-1">Select a Pay Plan</option>
                            @foreach (var group in payPlanGroups)
                            {
                                <optgroup label="@GroupLabel(group.Key)">
                                    @foreach (var payPlan in group)
                                    {
                                        <option value="@payPlan.Value">@payPlan.Text</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>

                    <div class="col-12 d-none" id="costSummaryFilter">
                        <label class="form-label" for="costSummaryList">Summary</label>
                        <select id="costSummaryList" class="form-select"></select>
                    </div>

                    <div class="col-12 d-none" id="categoryFilter">
                        <label class="form-label" for="categoryList">Category</label>
                        <select id="categoryList" class="form-select"></select>
                    </div>

                    <div class="col-12 d-none" id="locationFilter">
                        <label class="form-label" for="locationList">Locality / Location</label>
                        <select id="locationList" class="form-select" disabled></select>
                    </div>

                    <div class="col-12 d-none" id="strlFilter">
                        <label class="form-label" for="strlList">Science &amp; Technology Reinvention Laboratory</label>
                        <select id="strlList" class="form-select"></select>
                    </div>

                    <div class="col-12 d-none" id="dependentStatusFilter">
                        <label class="form-label" for="dependentStatusList">Dependent Status</label>
                        <select id="dependentStatusList" class="form-select">
                            <option value="-1">Select a Dependent Status</option>
                            <option value="average">Average</option>
                            <option value="with">With Dependents</option>
                            <option value="without">Without Dependents</option>
                        </select>
                    </div>

                    <div class="col-12 d-none" id="numberOfDependentsFilter">
                        <label class="form-label" for="numberOfDependentsList">Number of Dependents</label>
                        <select id="numberOfDependentsList" class="form-select">
                            <option value="-1">Number of Dependents</option>
                            <option value="0">0</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                        </select>
                    </div>

                    <div class="col-12 d-none" id="overheadPercentFilter">
                        <label class="form-label" for="overheadPercent">Overhead Percentage</label>
                        <div class="input-group">
                            <input id="overheadPercent" type="number" min="0" max="200" step="0.01" class="form-control" value="0" />
                            <span class="input-group-text">%</span>
                        </div>
                        <div class="form-text">Enter a number between 0 and 200.</div>
                    </div>

                    <div class="col-12 d-none" id="inflationFilter">
                        <label class="form-label" for="inflationConversionTypeList">Inflation (Base/Input Year: <strong>@Model.DefaultYear</strong>)</label>
                        <select id="inflationConversionTypeList" class="form-select mb-2">
                            <option value="ThenToThen" selected>Then Year to Then Year</option>
                            <option value="ThenToConstant">Then Year to Constant Dollars</option>
                        </select>
                        <label class="form-label" for="inflationYearList">Output / Target Year</label>
                        <select id="inflationYearList" class="form-select"></select>
                    </div>

                    <div class="col-12">
                        <button type="button" id="showCostsButton" class="btn btn-warning w-100 fw-bold">
                            Refresh Cost Table
                        </button>
                        <div class="form-text">
                            You <strong>must</strong> click <em>Refresh Cost Table</em> to retrieve the selected data.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>AMCOS Lite Results</span>
                <span id="liteLegend" class="small d-none"></span>
            </div>
            <div class="card-body">
                <div id="liteStatus" class="alert alert-info">Choose filters and refresh to retrieve cost data.</div>

                <div id="weaponSystemWarning" class="alert alert-danger d-none">
                    The Special Pay Scales listed in AMCOS show all of the occupations, grade levels, and locations
                    where the Special Scale applies. If you can find exactly what you are looking for with respect to
                    the occupation, grade level, and location in the table below, then it is covered by the Special
                    Scale and this table should be used. If not, use the GS pay plan to find the correct data.
                </div>

                <div id="amcosLiteChart" class="mb-3"></div>
                <div id="liteResults"></div>

                <ul class="small text-muted mt-3">
                    <li>Only use Contractor Cost Estimate (CCE) if there is not an existing or similar contract available.</li>
                    <li>Need a list of all the locality rates, or the locality rate for a specific ZIP code? Use the Data tab &rarr; ZIP Code tool.</li>
                    <li>AMCOS is in compliance with OSD DODI 7041.04.</li>
                    <li id="gfebsSelectAllWarning" class="d-none">
                        When selecting <strong>All</strong> from a drop down, AMCOS returns the average of all available
                        Cost Elements (CEs). Not all CEs may apply to your analysis (e.g., Non-Foreign COLA or Overseas
                        Allowances) &mdash; they only apply to positions located in areas that receive these benefits.
                    </li>
                </ul>
            </div>
        </div>

        <div class="card d-none" id="cceNote">
            <div class="card-header">CCE note</div>
            <div class="card-body">
                <ul class="mb-0">
                    <li>The highlighted salary threshold indicates a wage greater than @Model.CceMaxPayFootnote.ToString("C0") per year.</li>
                    <li>Wages and salaries accounted for @Model.CceWagesAndSalaries of employer compensation costs.</li>
                    <li>The average cost of benefits accounts for the remaining @Model.CceBenefitsAll of employer compensation.</li>
                    <li>A value of negative one [($1.00)] indicates a wage estimate is not available.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/c3/0.7.20/c3.min.css" />
    <script>
        window._defaultYear = '@Model.DefaultYear';
        window._userId = '@(User.Identity?.Name ?? string.Empty)';
        window._baseApiUrl = '/api';
        window._cceMaxPayFootnote = @Model.CceMaxPayFootnote.ToString(System.Globalization.CultureInfo.InvariantCulture);
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/5.16.0/d3.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/c3/0.7.20/c3.min.js"></script>
    <script src="~/dist/js/object-payplan.js"></script>
    <script src="~/dist/js/object-inflationyear.js"></script>
    <script src="~/dist/js/amcos-lite.js" asp-append-version="true"></script>
}
