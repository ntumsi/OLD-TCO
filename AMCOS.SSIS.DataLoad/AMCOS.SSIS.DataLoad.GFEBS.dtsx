                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset">[load_GFEBS].[Raw]</property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT SourceSystem,
       PayPlan,
       JobSeries,
       StateCountry,
       FunctionalAreaCode,
       FunctionalAreaText,
       CostCenterCode,
       CostCenterText,
       ActivityTypeCode,
       ActivityTypeText,
       FundsCenterCode,
       FundsCenterText,
       Fund,
       UICUCForManpower,
       Grade,
       CivilianTypeCode,
       CivilianTypeText,
       TempPositionCode,
       WorkScheduleCode,
       WorkScheduleText,
       PersonnelNumber,
       TDA_TOEParagraph,
       PostalCode1,
       PostalCode2,
       CostElementCode,
       CostElementText,
       PayPeriodEndDate,
       FiscalYear_Period,
       GRC_TypeHourCode,
       AmountPaid,
       PaidHours,
       ActualHourlyRate
FROM load_GFEBS.Raw
WHERE NOT EXISTS
(
    SELECT *
    FROM load_GFEBS.PersonnelNumberWithMultiplePositions
    WHERE PersonnelNumber = Raw.PersonnelNumber
);</property>
