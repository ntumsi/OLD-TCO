@page
@model AMCOS.Web.Core.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "User Management";
}

<h1 class="mb-4">User Management</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- ── Filter card ─────────────────────────────────────────────────────────── -->
<div class="card mb-4">
    <div class="card-header">Search Filters</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label asp-for="FirstName" class="form-label">First Name</label>
                <input asp-for="FirstName" class="form-control" placeholder="First name" />
            </div>
            <div class="col-md-2">
                <label asp-for="LastName" class="form-label">Last Name</label>
                <input asp-for="LastName" class="form-control" placeholder="Last name" />
            </div>
            <div class="col-md-2">
                <label asp-for="ArmyRank" class="form-label">Rank</label>
                <input asp-for="ArmyRank" class="form-control" placeholder="e.g. CPT" />
            </div>
            <div class="col-md-2">
                <label asp-for="Macom" class="form-label">Organization (MACOM)</label>
                <select asp-for="Macom" class="form-select">
                    <option value="">— All —</option>
                    @foreach (var org in Model.Organizations)
                    {
                        <option value="@org.Value">@org.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="OfficeName" class="form-label">Office Name</label>
                <input asp-for="OfficeName" class="form-control" placeholder="Office name" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Search</button>
                <a asp-page="Users" class="btn btn-outline-secondary flex-fill">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- ── Results card ───────────────────────────────────────────────────────── -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            Results
            @if (Model.Users.Count > 0)
            {
                <span class="badge bg-secondary ms-1">@Model.Users.Count</span>
            }
        </span>
        <form method="post" asp-page-handler="Export" class="d-inline">
            <input type="hidden" name="FirstName"  value="@Model.FirstName" />
            <input type="hidden" name="LastName"   value="@Model.LastName" />
            <input type="hidden" name="ArmyRank"   value="@Model.ArmyRank" />
            <input type="hidden" name="Macom"      value="@Model.Macom" />
            <input type="hidden" name="OfficeName" value="@Model.OfficeName" />
            <button type="submit" class="btn btn-sm btn-success">Export to Excel</button>
        </form>
    </div>

    <div class="card-body p-0">
        @if (!string.IsNullOrWhiteSpace(Model.LoadError))
        {
            <div class="alert alert-warning m-3">@Model.LoadError</div>
        }
        else if (Model.Users.Count == 0)
        {
            <p class="text-center text-muted py-4 mb-0">No users found matching your filters.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-sm align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Rank</th>
                            <th>Organization</th>
                            <th>Office</th>
                            <th>Account Type</th>
                            <th class="text-end">Logins</th>
                            <th>Last Login</th>
                            <th>Role</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            var isSelf = !string.IsNullOrEmpty(Model.CurrentUserId)
                                         && user.UserId == Model.CurrentUserId;
                            var isAdmin = string.Equals(user.Role, "Admin", StringComparison.OrdinalIgnoreCase);

                            <tr>
                                <td>@user.Name</td>
                                <td><small class="text-muted">@user.Email</small></td>
                                <td>@user.ArmyRank</td>
                                <td>@user.Macom</td>
                                <td>@user.OfficeName</td>
                                <td>@user.AccountType</td>
                                <td class="text-end">@user.LoginCount</td>
                                <td>
                                    <small>@(user.LastLogin.HasValue ? user.LastLogin.Value.ToString("g") : "—")</small>
                                </td>
                                <td>
                                    <span class="badge @(isAdmin ? "bg-danger" : "bg-secondary")">
                                        @(user.Role ?? "—")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="ToggleRole" class="d-inline">
                                        @* Hidden filter state so the POST handler can redirect back with active filters. *@
                                        <input type="hidden" name="userId"     value="@user.UserId" />
                                        <input type="hidden" name="FirstName"  value="@Model.FirstName" />
                                        <input type="hidden" name="LastName"   value="@Model.LastName" />
                                        <input type="hidden" name="ArmyRank"   value="@Model.ArmyRank" />
                                        <input type="hidden" name="Macom"      value="@Model.Macom" />
                                        <input type="hidden" name="OfficeName" value="@Model.OfficeName" />
                                        @if (isSelf)
                                        {
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-secondary"
                                                    disabled
                                                    title="You cannot change your own role">
                                                Toggle Role
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-warning"
                                                    title="Toggle role — currently @(user.Role ?? "unset")">
                                                Toggle Role
                                            </button>
                                        }
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
