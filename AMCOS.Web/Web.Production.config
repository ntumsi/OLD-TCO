<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
	<configProtectedData xdt:Transform="Insert">
		<providers>      
			<add name="OWP" type="System.Configuration.RsaProtectedConfigurationProvider, System.Configuration, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL" keyContainerName="OsmisPFE" useMachineContainer="true" />
		</providers>  
	</configProtectedData>
	<connectionStrings configProtectionProvider="OWP" xdt:Transform="Replace">
		<EncryptedData Type="http://www.w3.org/2001/04/xmlenc#Element" xmlns="http://www.w3.org/2001/04/xmlenc#">
			<EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#aes256-cbc" />
			<KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
				<EncryptedKey xmlns="http://www.w3.org/2001/04/xmlenc#">
					<EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#rsa-oaep-mgf1p" />
					<KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
						<KeyName>Rsa Key</KeyName>
					</KeyInfo>
					<CipherData>
						<CipherValue></CipherValue>
					</CipherData>
				</EncryptedKey>
			</KeyInfo>
			<CipherData>
				<CipherValue></CipherValue>
			</CipherData>
		</EncryptedData>
	</connectionStrings>
	<appSettings>
		<add key="AmcosUrl" value="https://www.cave.army.mil/amcos" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="CaveUrl" value="https://www.cave.army.mil" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="Environment" value="Production" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="SmtpHost" value="smtp.c1.5g.prod.army.mil" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
        <add key="InternalTester_NameIdentifier" value="marsha.popp" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
        <add key="InternalTester_GIVENNAME" value="Marsha" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
        <add key="InternalTester_SN" value="Popp" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
        <add key="InternalTester_Department" value="" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
        <add key="InternalTester_ARMYACCOUNTTYPE" value="CIVILIAN" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
        <add key="InternalTester_PreferredUserName" value="123Marsha" xdt:Transform="Remove" xdt:Locator="Match(key)" />
		<add key="InternalTester_Name" value ="John Wick" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
		<add key="InternalTester_Role" value="amcos_admin" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
        <add key="InternalTester_Email" value="marshaEmail@mail.mil" xdt:Transform="Remove" xdt:Locator="Match(key)"/>	   
		<add key="AwsAccountId" value="454826935417" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="FeatureFlag-QuickSight-PaySchedule" value="true" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="FeatureFlag-QuickSight-GSLocalityRatesByZipCode" value="true" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="FeatureFlag-QuickSightAdminReports" value="true" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="FeatureFlag-QuickSight-CostCompare" value="true" xdt:Transform="Replace" xdt:Locator="Match(key)" />
  </appSettings>
	<system.net>
		<mailSettings>
			<smtp deliveryMethod="Network" xdt:Transform="Replace">
				<network host="smtp.c1.5g.prod.army.mil" port="25" />
			</smtp>
		</mailSettings>
	</system.net>
  <system.web>
    <customErrors mode="On" xdt:Transform="SetAttributes(mode)"/>
    <compilation debug="false" xdt:Transform="SetAttributes(debug)"/>    
    <authorization>
      <allow users="*" xdt:Transform="Remove"/>
      <deny users="?" xdt:Transform="Insert"/>
    </authorization>
    <healthMonitoring>
      <providers>
        <add name="MailWebEventProvider" type="System.Web.Management.SimpleMailWebEventProvider" from="no-reply@cave.army.mil" to="benedict.j.mays.ctr@army.mil" buffer="false" subjectPrefix="AMCOS Production:  " xdt:Transform="Replace" xdt:Locator="Match(name)"/>
      </providers>
    </healthMonitoring>
  </system.web>
  <system.webServer>
    <rewrite>
      <rules xdt:Transform="Insert">
        <rule name="Redirect Login.aspx" stopProcessing="true">
          <match url="login.aspx"/>
          <action type="Redirect" url="https://www.cave.army.mil/amcos"/>
        </rule>
        <rule name="Redirect Payschedule" stopProcessing="true">
          <match url="payschedule.aspx"/>
          <action type="Redirect" url="https://www.cave.army.mil/amcos/Visualization/Payschedule"/>
        </rule>
        <rule name="Redirect Inventory" stopProcessing="true">
          <match url="inventory.aspx"/>
          <action type="Redirect" url="https://www.cave.army.mil/amcos/Visualization/Inventory"/>
        </rule>
        <rule name="Redirect ComparisonAnalysis" stopProcessing="true">
          <match url="ComparisonAnalysis"/>
          <action type="Redirect" url="https://www.cave.army.mil/amcos/Admin/CostCompare"/>
        </rule>
        <rule name="Redirect Home.aspx" stopProcessing="true">
          <match url="home.aspx"/>
          <action type="Redirect" url="https://www.cave.army.mil/amcos/home"/>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>