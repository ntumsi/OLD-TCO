@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AMCOS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/amcos.css" />
    <link rel="alternate" type="application/rss+xml" title="Army Military-Civilian Cost System (AMCOS)" href="~/Public/rss.xml" />
</head>
<body>
    <header class="mb-4">
        <nav class="navbar navbar-expand-lg amcos-navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-page="/Index"><span class="amcos-brand-mark"></span>AMCOS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                        @* Applications dropdown mirrors the legacy menu grouping. *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Applications</a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-page="/App/Lite/Index">AMCOS Lite</a></li>
                                <li><a class="dropdown-item" asp-page="/App/Project/Index">Project Manager</a></li>
                                <li><a class="dropdown-item" asp-page="/App/Xwalk/Index">Pay Plan Xwalk</a></li>
                                <li><a class="dropdown-item" asp-page="/App/CivilianPcs/Index">Civilian PCS</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Data</a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-page="/App/Data/Visualization" asp-route-slug="inventory">Inventory</a></li>
                                <li><a class="dropdown-item" asp-page="/App/Data/Visualization" asp-route-slug="pay-schedule">Pay Schedule</a></li>
                                <li><a class="dropdown-item" asp-page="/App/Data/Visualization" asp-route-slug="locality-rates">GS Locality Rates By ZIP Code</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-page="/App/Data/Calculations">Cost Elements</a></li>
                                <li><a class="dropdown-item" asp-page="/App/Data/Skills">Skills Browser</a></li>
                            </ul>
                        </li>
                        <li class="nav-item"><a class="nav-link" asp-page="/App/Profile/Index">My Profile</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            @* Administration submenu ordered/labelled to mirror the legacy menu; Core-only items follow the divider. *@
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Administration</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-page="/Admin/Users">User List</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Log">Event Log</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Dashboard" asp-route-slug="cost-compare">Cost Compare</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Dashboard" asp-route-slug="lite-usage">AMCOS Lite Usage</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Approvals">AMCOS User Approvals</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Dashboard" asp-route-slug="user-logins">AMCOS User Logins</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Dashboard" asp-route-slug="active-users">Current Active AMCOS Users</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Dashboard" asp-route-slug="helpspot">HelpSpot Historical Data</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Index">Dashboards</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/SponsorAction">Sponsor Actions</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Inventory">Inventory Compare</a></li>
                                </ul>
                            </li>
                        }
                        @* Legacy "Help Docs" equivalent — kept at the end of the bar, expanded with the migrated Help/News/Resources additions. *@
                        <li class="nav-item"><a class="nav-link" asp-page="/Help">Help</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Notes">Release Notes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Note">News</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Resources</a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><h6 class="dropdown-header">Primary Documents</h6></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS CBA Guide.pdf" target="_blank">Cost Benefit Analysis Guide</a></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS Fact Sheet.pdf" target="_blank">Fact Sheet</a></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS FAQ.pdf" target="_blank">Frequently Asked Questions</a></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS Release Update History.pdf" target="_blank">Release Notes/Update History</a></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS Cost Model Documentation.pdf" target="_blank">Cost Model Documentation</a></li>
                                <li><a class="dropdown-item" asp-page="/App/Data/Calculations">Cost Element Data Dictionary</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Methodologies</h6></li>
                                <li><a class="dropdown-item" href="~/Public/Contractor Cost Estimate Methodology.pdf" target="_blank">Contractor Cost Estimate</a></li>
                                <li><a class="dropdown-item" href="~/Public/Inflation and Discounting PVF Calculation Methodology.pdf" target="_blank">Inflation and Discounting</a></li>
                                <li><a class="dropdown-item" href="~/Public/Pay Plan Xwalk Methodology.pdf" target="_blank">Pay Plan Xwalk</a></li>
                                <li><a class="dropdown-item" href="~/Public/Salary Calculation Methodology.pdf" target="_blank">Salary Calculation</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">Tutorials</h6></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS Civilian PCS.pdf" target="_blank">AMCOS Civilian PCS</a></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS LITE Tutorial.pdf" target="_blank">AMCOS Lite</a></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS Project Manager Tutorial.pdf" target="_blank">AMCOS Project Manager</a></li>
                                <li><a class="dropdown-item" href="~/Public/AMCOS Pay Plan Xwalk Tutorial.pdf" target="_blank">AMCOS Pay Plan Xwalk</a></li>
                                <li><a class="dropdown-item" href="~/Public/AESMP User Primer.pdf" target="_blank">How to Submit a Request in AESMP</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" href="~/Public/HistoricalDatabaseLinksList.pdf" target="_blank">Data Exports prior to 2020</a></li>
                                <li><a class="dropdown-item" asp-page="/Help">Request Data Export</a></li>
                                <li><a class="dropdown-item" href="~/Public/ARMY CES Xwalk.xlsx" target="_blank">Army Current-Former CES Xwalk</a></li>
                            </ul>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3 text-white">
                        <a href="https://www.asafm.army.mil" target="_blank" rel="noopener" class="nav-link p-0" title="Open the ASA (FM&amp;C) Portal in a new window.">ASA (FM&amp;C)</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/App/Profile/Index" class="btn btn-outline-secondary btn-sm">
                                @(User.FindFirst(ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? "My Profile")
                            </a>
                            <form id="amcos-logout-form" asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                            </form>
                        }
                        else
                        {
                            <span>Anonymous</span>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Login</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="container pb-4">
        @RenderBody()
    </main>

    <footer class="amcos-footer mt-4">
        <div class="container d-flex flex-wrap justify-content-between align-items-center py-3 gap-2">
            <span>&copy; @DateTime.UtcNow.Year AMCOS &mdash; Army Civilian and Military Operational Support</span>
            <span class="d-flex gap-3">
                <a asp-page="/Privacy">Privacy</a>
                <a asp-page="/Help">Help</a>
                <a asp-page="/About">About</a>
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/site.js"></script>

    <!-- Session expiry warning modal -->
    <div class="modal fade" id="SessionExpiringModal" tabindex="-1" aria-labelledby="sessionModalLabel" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="sessionModalLabel">Session Expiring</h5>
                </div>
                <div class="modal-body">
                    Your session will expire in <strong><span id="SessionMinutes">0</span>m <span id="SessionSeconds">00</span>s</strong>.
                    Move your mouse or press a key to stay logged in.
                </div>
            </div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
