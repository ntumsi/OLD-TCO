			</namespaces>
			<controls>
				<add tagPrefix="ajaxToolkit" assembly="AjaxControlToolkit" namespace="AjaxControlToolkit" />
			</controls>
		</pages>		
		<authorization>
			<allow users="*" />
		</authorization>
		<healthMonitoring enabled="true">
			<eventMappings>
				<clear />
				<add name="AMCOS: All Errors" type="System.Web.Management.WebBaseErrorEvent" startEventCode="0" endEventCode="2147483647" />
			</eventMappings>
			<providers>
				<clear />
				<add name="SqlWebEventProvider" connectionStringName="AmcosAdo" maxEventDetailsLength="1073741823" buffer="false" type="System.Web.Management.SqlWebEventProvider" />
				<add name="AmcosMailWebEventProvider" type="System.Web.Management.TemplatedMailWebEventProvider" template="template.aspx" detailedTemplateErrors="true" to="gregory.d.bonner2.ctr@army.mil, russell.t.willbanks.ctr@army.mil, benedict.j.mays.ctr@army.mil" from="amcos-cave-helpdesk@army.mil" buffer="false" />
			</providers>
			<rules>
				<clear />
				<add name="Log Errors To Database" eventName="AMCOS: All Errors" provider="SqlWebEventProvider" profile="Default" minInstances="1" maxLimit="Infinite" minInterval="00:00:00" />
				<add name="Testing Templated Mail Event Provider" eventName="AMCOS: All Errors" provider="AmcosMailWebEventProvider" profile="Default" minInstances="1" maxLimit="Infinite" minInterval="00:00:00" custom="" />
			</rules>
		</healthMonitoring>
		<httpRuntime executionTimeout="900" requestValidationMode="2.0" targetFramework="4.5" maxRequestLength="512000" enableVersionHeader="false" />
		<globalization fileEncoding="utf-8" requestEncoding="utf-8" responseEncoding="utf-8" culture="en-US" uiCulture="de-DE" />
	</system.web>
	<location path="dist/img">
		<system.web>
			<authorization>
