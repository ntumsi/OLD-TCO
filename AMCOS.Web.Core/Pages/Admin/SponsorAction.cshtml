@page
@model AMCOS.Web.Core.Pages.Admin.SponsorActionModel
@{
    ViewData["Title"] = "Sponsor Action — Pending Approvals";
}

<h1>Sponsor Action — Pending Approvals</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.LoadError))
{
    <div class="alert alert-danger">@Model.LoadError</div>
}

<div class="card">
    <div class="card-header">Users Awaiting Your Sponsorship</div>
    <div class="card-body p-0">
        @if (!Model.PendingUsers.Any())
        {
            <div class="alert alert-info m-3 mb-0">No users awaiting your sponsorship approval.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-sm align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Office</th>
                            <th>Organization</th>
                            <th>Account Type</th>
                            <th>Rank</th>
                            <th>Company</th>
                            <th>Last Login</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.PendingUsers)
                        {
                            <tr>
                                <td>@u.FullName</td>
                                <td>@u.Email</td>
                                <td>@u.Phone</td>
                                <td>@u.OfficeName</td>
                                <td>@u.Macom</td>
                                <td>@u.AccountType</td>
                                <td>@u.ArmyRank</td>
                                <td>@u.CompanyName</td>
                                <td>@u.LastLogin?.ToString("g")</td>
                                <td class="text-end text-nowrap">
                                    <form method="post" asp-page-handler="Approve" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.UserId" />
                                        <input type="hidden" name="userName" value="@u.FullName" />
                                        <button type="submit" class="btn btn-sm btn-success"
                                                onclick="return confirm('Approve @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(u.FullName ?? string.Empty))? This will forward their account for admin review.')">
                                            Approve
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Deny" class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.UserId" />
                                        <input type="hidden" name="userName" value="@u.FullName" />
                                        <button type="submit" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Deny @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(u.FullName ?? string.Empty))? This will reject their registration.')">
                                            Deny
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
