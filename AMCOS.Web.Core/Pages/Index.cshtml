@page
@model AMCOS.Web.Core.Pages.IndexModel
@{
    ViewData["Title"] = "AMCOS Home";
}

<div class="amcos-home rounded-3 border overflow-hidden position-relative"
     style="background-image:url('@Model.BackgroundImageUrl'); background-size:cover; background-position:center; min-height:440px;">
    <div class="p-4 p-md-5 d-flex flex-column h-100 text-white" style="background:rgba(0,0,0,0.55); min-height:440px;">
        <p class="lead" style="max-width:820px;">
            <span class="fw-bold display-6 align-middle">AMCOS</span>
            is an automated tool that helps users estimate the costs associated with personnel
            requirements for different components, grades and skills. AMCOS contains a comprehensive
            database of personnel-related cost factors for the Active, the Reserve Components, the
            Civilian workforce, and the Contractor Cost Estimate (CCE).
        </p>

        <div class="mb-3">
            <span class="fw-bold">What's New</span><br />
            Current Release: Jan 2025<br />
            Next Full Release: July 2026
        </div>

        <p class="mb-4">
            For full details on the latest release please see the
            <a class="link-light fw-semibold" target="_blank"
               href="/Public/AMCOS%20Release%20Update%20History.pdf">AMCOS Release/Update History</a>.
        </p>

        <div class="mt-auto">
            <a class="btn btn-primary btn-lg" asp-page="/About">Introduction &#9654;</a>
        </div>
    </div>
</div>