@page
@model AMCOS.Web.Core.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "User Management";
    // Current filter state, emitted as hidden inputs in each POST form so filters survive
    // role-toggle / delete / export round-trips.
    string? D(DateTime? d) => d?.ToString("yyyy-MM-dd");
    var filterFields = new Dictionary<string, string?>
    {
        ["FirstName"] = Model.FirstName,
        ["LastName"] = Model.LastName,
        ["ArmyRank"] = Model.ArmyRank,
        ["Macom"] = Model.Macom,
        ["OfficeName"] = Model.OfficeName,
        ["CompanyName"] = Model.CompanyName,
        ["CreatedFrom"] = D(Model.CreatedFrom),
        ["CreatedTo"] = D(Model.CreatedTo),
        ["LastLoginFrom"] = D(Model.LastLoginFrom),
        ["LastLoginTo"] = D(Model.LastLoginTo),
        ["ApprovedFrom"] = D(Model.ApprovedFrom),
        ["ApprovedTo"] = D(Model.ApprovedTo),
        ["DeniedFrom"] = D(Model.DeniedFrom),
        ["DeniedTo"] = D(Model.DeniedTo),
    };
}

<h1 class="mb-4">User Management</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- ── Filter card ─────────────────────────────────────────────────────────── -->
<div class="card mb-4">
    <div class="card-header">Search Filters</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label asp-for="FirstName" class="form-label">First Name</label>
                <input asp-for="FirstName" class="form-control" placeholder="First name" />
            </div>
            <div class="col-md-2">
                <label asp-for="LastName" class="form-label">Last Name</label>
                <input asp-for="LastName" class="form-control" placeholder="Last name" />
            </div>
            <div class="col-md-2">
                <label asp-for="ArmyRank" class="form-label">Rank</label>
                <input asp-for="ArmyRank" class="form-control" placeholder="e.g. CPT" />
            </div>
            <div class="col-md-2">
                <label asp-for="Macom" class="form-label">Organization (MACOM)</label>
                <select asp-for="Macom" class="form-select">
                    <option value="">— All —</option>
                    @foreach (var org in Model.Organizations)
                    {
                        <option value="@org.Value">@org.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="OfficeName" class="form-label">Office Name</label>
                <input asp-for="OfficeName" class="form-control" placeholder="Office name" />
            </div>
            <div class="col-md-2">
                <label asp-for="CompanyName" class="form-label">Company</label>
                <input asp-for="CompanyName" class="form-control" placeholder="Company name" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Created (from / to)</label>
                <div class="input-group">
                    <input asp-for="CreatedFrom" type="date" class="form-control" />
                    <input asp-for="CreatedTo" type="date" class="form-control" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Last Login (from / to)</label>
                <div class="input-group">
                    <input asp-for="LastLoginFrom" type="date" class="form-control" />
                    <input asp-for="LastLoginTo" type="date" class="form-control" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Approved (from / to)</label>
                <div class="input-group">
                    <input asp-for="ApprovedFrom" type="date" class="form-control" />
                    <input asp-for="ApprovedTo" type="date" class="form-control" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Denied (from / to)</label>
                <div class="input-group">
                    <input asp-for="DeniedFrom" type="date" class="form-control" />
                    <input asp-for="DeniedTo" type="date" class="form-control" />
                </div>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Search</button>
                <a asp-page="Users" class="btn btn-outline-secondary flex-fill">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- ── Results card ───────────────────────────────────────────────────────── -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            Results
            @if (Model.Users.Count > 0)
            {
                <span class="badge bg-secondary ms-1">@Model.Users.Count</span>
            }
        </span>
        <form method="post" asp-page-handler="Export" class="d-inline">
            @foreach (var f in filterFields)
            {
                <input type="hidden" name="@f.Key" value="@f.Value" />
            }
            <button type="submit" class="btn btn-sm btn-success">Export to Excel</button>
        </form>
    </div>

    <div class="card-body p-0">
        @if (!string.IsNullOrWhiteSpace(Model.LoadError))
        {
            <div class="alert alert-warning m-3">@Model.LoadError</div>
        }
        else if (Model.Users.Count == 0)
        {
            <p class="text-center text-muted py-4 mb-0">No users found matching your filters.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-sm align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Rank</th>
                            <th>Organization</th>
                            <th>Office</th>
                            <th>Account Type</th>
                            <th class="text-end">Logins</th>
                            <th>Last Login</th>
                            <th>Role</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            var isSelf = !string.IsNullOrEmpty(Model.CurrentUserId)
                                         && user.UserId == Model.CurrentUserId;
                            var isAdmin = string.Equals(user.Role, "Admin", StringComparison.OrdinalIgnoreCase);

                            <tr>
                                <td>@user.Name</td>
                                <td><small class="text-muted">@user.Email</small></td>
                                <td>@user.ArmyRank</td>
                                <td>@user.Macom</td>
                                <td>@user.OfficeName</td>
                                <td>@user.AccountType</td>
                                <td class="text-end">@user.LoginCount</td>
                                <td>
                                    <small>@(user.LastLogin.HasValue ? user.LastLogin.Value.ToString("g") : "—")</small>
                                </td>
                                <td>
                                    <span class="badge @(isAdmin ? "bg-danger" : "bg-secondary")">
                                        @(user.Role ?? "—")
                                    </span>
                                </td>
                                <td class="text-end text-nowrap">
                                    <form method="post" asp-page-handler="ToggleRole" class="d-inline">
                                        @* Hidden filter state so the POST handler can redirect back with active filters. *@
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        @foreach (var f in filterFields)
                                        {
                                            <input type="hidden" name="@f.Key" value="@f.Value" />
                                        }
                                        @if (isSelf)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" disabled
                                                    title="You cannot change your own role">Toggle Role</button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-warning"
                                                    title="Toggle role — currently @(user.Role ?? "unset")">Toggle Role</button>
                                        }
                                    </form>
                                    <form method="post" asp-page-handler="Delete" class="d-inline"
                                          onsubmit="return confirm('Permanently delete @user.Name and ALL of their projects, reports and login history? This cannot be undone.');">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        @foreach (var f in filterFields)
                                        {
                                            <input type="hidden" name="@f.Key" value="@f.Value" />
                                        }
                                        @if (isSelf)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" disabled
                                                    title="You cannot delete your own account">Delete</button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    title="Permanently delete this user and all their data">Delete</button>
                                        }
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
