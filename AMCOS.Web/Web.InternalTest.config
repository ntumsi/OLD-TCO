<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <connectionStrings configProtectionProvider="RsaProtectedConfigurationProvider" xdt:Transform="Replace" >
	  <EncryptedData Type="http://www.w3.org/2001/04/xmlenc#Element"
   xmlns="http://www.w3.org/2001/04/xmlenc#">
		  <EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#aes256-cbc" />
		  <KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
			  <EncryptedKey xmlns="http://www.w3.org/2001/04/xmlenc#">
				  <EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#rsa-oaep-mgf1p" />
				  <KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
					  <KeyName>Rsa Key</KeyName>
				  </KeyInfo>
				  <CipherData>
					  <CipherValue></CipherValue>
				  </CipherData>
			  </EncryptedKey>
		  </KeyInfo>
		  <CipherData>
			  <CipherValue></CipherValue>
		  </CipherData>
	  </EncryptedData>
  </connectionStrings>
  <appSettings>	
    <add key="Environment" value="InternalTest" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
    <add key="CaveUrl" value="https://CAADW00GAAC2001.c1.5g.dev.army.mil" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
  </appSettings>
	<secureAppSettings configProtectionProvider="RsaProtectedConfigurationProvider" xdt:Transform="Replace">
		<EncryptedData Type="http://www.w3.org/2001/04/xmlenc#Element"
		 xmlns="http://www.w3.org/2001/04/xmlenc#">
			<EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#aes256-cbc" />
			<KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
				<EncryptedKey xmlns="http://www.w3.org/2001/04/xmlenc#">
					<EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#rsa-oaep-mgf1p" />
					<KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
						<KeyName>Rsa Key</KeyName>
					</KeyInfo>
					<CipherData>
						<CipherValue></CipherValue>
					</CipherData>
				</EncryptedKey>
			</KeyInfo>
			<CipherData>
				<CipherValue>bXHcmLBcdaDWBnkxGieZFx3jaOOU99hRkIbXUSdFJtd+7FOLhlBfu+pL5KeyW4M3yFykhDfVrmDxiKVErZECxE3jK6/lDKnbLS2oZhp9UmMYKSFRQ8wkUIMiojhB8nZ9HH4ny3rGUdp1f+b/qiYplsPRr22+9AdHHWQWLN0waV/XAHBVBvvdJxYbXAKNrFKD</CipherValue>
			</CipherData>
		</EncryptedData>
	</secureAppSettings>
  <system.web>
    <compilation debug="false" xdt:Transform="SetAttributes(debug)"/>
	  <authorization>
		  <deny users="?" xdt:Transform="Insert"/>
	  </authorization>
  </system.web>
  <system.webServer>
    <rewrite>
      <rules xdt:Transform="Insert">
        <rule name="Redirect Login.aspx" stopProcessing="true">
          <match url="login.aspx"/>
          <action type="Redirect" url="https://caadw00gaac2001.c1.5g.dev.army.mil/amcos"/>
        </rule>
        <rule name="Redirect Payschedule" stopProcessing="true">
          <match url="payschedule.aspx"/>
          <action type="Redirect" url="https://caadw00gaac2001.c1.5g.dev.army.mil/amcos/Visualization/Payschedule"/>
        </rule>
        <rule name="Redirect Inventory" stopProcessing="true">
          <match url="inventory.aspx"/>
          <action type="Redirect" url="https://caadw00gaac2001.c1.5g.dev.army.mil/amcos/Visualization/Inventory"/>
        </rule>
        <rule name="Redirect ComparisonAnalysis" stopProcessing="true">
          <match url="ComparisonAnalysis"/>
          <action type="Redirect" url="https://caadw00gaac2001.c1.5g.dev.army.mil/amcos/Admin/CostCompare"/>
        </rule>
        <rule name="Redirect Home.aspx" stopProcessing="true">
          <match url="home.aspx"/>
          <action type="Redirect" url="https://caadw00gaac2001.c1.5g.dev.army.mil/amcos/home"/>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>