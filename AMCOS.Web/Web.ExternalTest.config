<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
	<connectionStrings configProtectionProvider="RsaProtectedConfigurationProvider" xdt:Transform="Replace">
		<EncryptedData Type="http://www.w3.org/2001/04/xmlenc#Element"
		 xmlns="http://www.w3.org/2001/04/xmlenc#">
			<EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#aes256-cbc" />
			<KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
				<EncryptedKey xmlns="http://www.w3.org/2001/04/xmlenc#">
					<EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#rsa-oaep-mgf1p" />
					<KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
						<KeyName>Rsa Key</KeyName>
					</KeyInfo>
					<CipherData>
						<CipherValue></CipherValue>
					</CipherData>
				</EncryptedKey>
			</KeyInfo>
			<CipherData>
				<CipherValue></CipherValue>
			</CipherData>
		</EncryptedData>
	</connectionStrings>
	<appSettings>
		<add key="AmcosUrl" value="https://testweb.cave.army.mil/amcos/oidc-callback" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="CaveUrl" value="https://testweb.cave.army.mil" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="Environment" value="ExternalTest" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="InternalTester_NameIdentifier" value="marsha.popp" xdt:Transform="Remove" xdt:Locator="Match(key)" />
		<add key="InternalTester_GIVENNAME" value="Marsha" xdt:Transform="Remove" xdt:Locator="Match(key)" />
		<add key="InternalTester_SN" value="Popp" xdt:Transform="Remove" xdt:Locator="Match(key)" />
		<add key="InternalTester_Department" value="" xdt:Transform="Remove" xdt:Locator="Match(key)" />
		<add key="InternalTester_ARMYACCOUNTTYPE" value="CIVILIAN" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
		<add key="InternalTester_PreferredUserName" value="123Marsha" xdt:Transform="Remove" xdt:Locator="Match(key)" />
		<add key="InternalTester_Name" value ="John Wick" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
		<add key="InternalTester_Role" value="amcos_admin" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
		<add key="InternalTester_Email" value="marshaEmail@mail.mil" xdt:Transform="Remove" xdt:Locator="Match(key)"/>		
		<add key="FeatureFlag-QuickSight-GSLocalityRatesByZipCode" value="true" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="FeatureFlag-QuickSight-PaySchedule" value="true" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="FeatureFlag-QuickSight-AdminReports" value="true" xdt:Transform="Replace" xdt:Locator="Match(key)" />
		<add key="GSLocalityRatesByZipCodeDashboardId" value="6260f52d-b32b-41ed-a6cc-a334314bf654" xdt:Transform="Replace" xdt:Locator="Match(key)"/>	
		<add key="PayScheduleDashboardId" value="6b8daba1-78f7-4dbd-ae61-40fccf67f971" xdt:Transform="Replace" xdt:Locator="Match(key)" />		
		<add key="AmcosUserLoginsDashboardId" value="474080f5-9fd5-42fe-9d05-3e62306428f5" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="AmcosUserApprovalsDashboardId" value="fd86d412-47c0-4b25-bc90-07ddff321f65" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="AmcosLiteUsageDashboardId" value="47cd9f6f-1d1d-4799-bbfb-4bc7eb99cfa7" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="CostCompareDashboardId" value="6ed319b6-83f6-41fb-9b3c-7f11254e2702" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="CurrentActiveAmcosUsersDashboardId" value="5eb70793-a8ef-490a-ad81-2e2b9b058977" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="InventoryDashboardId" value="31d30ece-2f2a-4296-b4d8-676a945fdea5" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="KeyCloakClientId" value="amcos-test" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
		<add key="KeyCloakAuthority" value="https://test.cave.army.mil/auth/realms/cave/" xdt:Transform="Replace" xdt:Locator="Match(key)"/>
	</appSettings>	
	<secureAppSettings configProtectionProvider="RsaProtectedConfigurationProvider"  xdt:Transform="Replace" >
	  <EncryptedData Type="http://www.w3.org/2001/04/xmlenc#Element"
	   xmlns="http://www.w3.org/2001/04/xmlenc#">
	   <EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#aes256-cbc" />
	   <KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
		<EncryptedKey xmlns="http://www.w3.org/2001/04/xmlenc#">
		 <EncryptionMethod Algorithm="http://www.w3.org/2001/04/xmlenc#rsa-oaep-mgf1p" />
		 <KeyInfo xmlns="http://www.w3.org/2000/09/xmldsig#">
		  <KeyName>Rsa Key</KeyName>
		 </KeyInfo>
		 <CipherData>
		  <CipherValue></CipherValue>
		 </CipherData>
		</EncryptedKey>
	   </KeyInfo>
	   <CipherData>
		<CipherValue>77HYWXWnykXPNjI1DzBYRdBxx2cCe4hx48aVfdiJgE19rJPsydmYPGd+hRhx5j4jACIYAKDSL1CkNnDpIeWrAzRAjc79TYNR4AqFewNk/QYJ5Zkl4E1+BV0b/HTRvi7+r8fle0XduLHtPN2w3igDVTGb51qD6VpXW3927AeYHnidJ9h0fR0xT+qf0Cy000bs</CipherValue>
	   </CipherData>
	  </EncryptedData>
 </secureAppSettings>
  <system.web>
    <customErrors mode="On" xdt:Transform="SetAttributes(mode)" />
    <compilation debug="false" xdt:Transform="SetAttributes(debug)" />   
    <authorization>
      <deny users="?" xdt:Transform="Insert"/>
    </authorization>
  </system.web>
  <system.webServer>
    <rewrite>
      <rules xdt:Transform="Insert">
        <rule name="Redirect Login.aspx" stopProcessing="true">
          <match url="login.aspx"/>
          <action type="Redirect" url="https://testweb.cave.army.mil/amcos"/>
        </rule>
        <rule name="Redirect Payschedule" stopProcessing="true">
          <match url="payschedule.aspx"/>
          <action type="Redirect" url="https://testweb.cave.army.mil/amcos/Visualization/Payschedule"/>
        </rule>
        <rule name="Redirect Inventory" stopProcessing="true">
          <match url="inventory.aspx"/>
          <action type="Redirect" url="https://testweb.cave.army.mil/amcos/Visualization/Inventory"/>
        </rule>
        <rule name="Redirect ComparisonAnalysis" stopProcessing="true">
          <match url="ComparisonAnalysis"/>
          <action type="Redirect" url="https://testweb.cave.army.mil/amcos/Admin/CostCompare"/>
        </rule>
        <rule name="Redirect Home.aspx" stopProcessing="true">
          <match url="home.aspx"/>
          <action type="Redirect" url="https://testweb.cave.army.mil/amcos/home"/>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>