@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AMCOS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/dist/css/site.css" />
</head>
<body>
    <header class="border-bottom mb-4">
        <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-page="/Index">AMCOS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/App/Lite/Index">AMCOS Lite</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/App/Project/Index">Project Manager</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/App/Xwalk/Index">Xwalk</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/App/CivilianPcs/Index">Civilian PCS</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Index">Admin</a></li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3 text-white">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span>@(User.FindFirst(ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? "Authenticated User")</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                            </form>
                        }
                        else
                        {
                            <span>Anonymous</span>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Login</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="container pb-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
