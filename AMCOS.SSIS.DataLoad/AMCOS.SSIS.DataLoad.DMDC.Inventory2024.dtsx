                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT OccupationalSeriesNumber,
       SeriesTitle,
       WorkRoleCodeRequired,
       AmcosVersionIdStart,
       AmcosVersionIdEnd
FROM lookup.GS_OccupationalSeries
WHERE 202501
BETWEEN AmcosVersionIdStart AND AmcosVersionIdEnd;</property>
