@page "{projectId:int?}"
@model AMCOS.Web.Core.Pages.App.Project.ReportModel
@{
    ViewData["Title"] = "Project Report";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Project Manager Report</h1>
        <p class="text-muted mb-0">Project Id: @(Model.ProjectId?.ToString() ?? "Not supplied")</p>
    </div>
    @if (Model.ProjectId.HasValue)
    {
        <form method="post" asp-page-handler="Export">
            <input type="hidden" name="projectId" value="@Model.ProjectId" />
            <button type="submit" class="btn btn-success">Export Excel</button>
        </form>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.LoadError))
{
    <div class="alert alert-warning">@Model.LoadError</div>
}
else if (Model.ProjectDetails is null)
{
    <div class="alert alert-info">Select a project from Project Manager to load report data.</div>
}
else
{
    <div class="row g-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">Report Properties</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Project Name</dt><dd class="col-sm-9">@Model.ProjectDetails.ProjectName</dd>
                        <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.ProjectDetails.Description</dd>
                        <dt class="col-sm-3">Project Creator</dt><dd class="col-sm-9">@Model.ProjectDetails.ProjectCreator</dd>
                        <dt class="col-sm-3">Start Year</dt><dd class="col-sm-9">@Model.ProjectDetails.YearStart</dd>
                        <dt class="col-sm-3">Duration</dt><dd class="col-sm-9">@Model.ProjectDetails.YearDuration</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header">Report Selection</div>
                <div class="card-body">
                    @await Html.PartialAsync("_DataTable", Model.ReportSelections)
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header">Inflation Factors</div>
                <div class="card-body">
                    @await Html.PartialAsync("_DataTable", Model.InflationFactors)
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header">Discount Factors and Present Value</div>
                <div class="card-body">
                    @await Html.PartialAsync("_DataTable", Model.DiscountTable)
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header">Inventory</div>
                <div class="card-body">
                    @await Html.PartialAsync("_DataTable", Model.InventoryTable)
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header">Cost Report</div>
                <div class="card-body">
                    @await Html.PartialAsync("_DataTable", Model.CostReport)
                </div>
            </div>
        </div>
    </div>
}
