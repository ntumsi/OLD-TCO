       SeriesTitle,
       WorkRoleCodeRequired,
       AmcosVersionIdStart,
       AmcosVersionIdEnd
FROM lookup.GS_OccupationalSeries
WHERE 202501
BETWEEN AmcosVersionIdStart AND AmcosVersionIdEnd;) [refTable]
where [refTable].[OccupationalSeriesNumber] = ?</property>
